<Project>
  <PropertyGroup>
    <SVappsLAB_iRacingTelemetrySDK_AGENTS_Source>$(MSBuildThisFileDirectory)..\contentFiles\any\any\.ai\SVappsLAB.iRacingTelemetrySDK\AGENTS.md</SVappsLAB_iRacingTelemetrySDK_AGENTS_Source>
    <SVappsLAB_iRacingTelemetrySDK_AGENTS_Target>$(MSBuildProjectDirectory)\.ai\SVappsLAB.iRacingTelemetrySDK\AGENTS.md</SVappsLAB_iRacingTelemetrySDK_AGENTS_Target>
  </PropertyGroup>

  <Target Name="CopySVappsLAB_iRacingTelemetrySDK_AGENTS" BeforeTargets="BeforeBuild">
    <MakeDir Directories="$(MSBuildProjectDirectory)\docs\SVappsLAB.iRacingTelemetrySDK" />
    <Copy SourceFiles="$(SVappsLAB_iRacingTelemetrySDK_AGENTS_Source)"
          DestinationFiles="$(SVappsLAB_iRacingTelemetrySDK_AGENTS_Target)"
          SkipUnchangedFiles="true" />
    <ItemGroup>
      <FileWrites Include="$(SVappsLAB_iRacingTelemetrySDK_AGENTS_Target)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <None Include="$(SVappsLAB_iRacingTelemetrySDK_AGENTS_Target)" Visible="true" Condition="Exists('$(SVappsLAB_iRacingTelemetrySDK_AGENTS_Target)')" />
  </ItemGroup>
</Project>
